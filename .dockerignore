# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
apps/*/dist/
packages/*/dist/
*.tsbuildinfo

# Local data — must NEVER bake into the image
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Source control / metadata
.git/
.gitignore
.github/
.cursor/

# Logs / coverage / temp
*.log
coverage/
.npm/
.pnpm-store/
.opencode/

# Editor / OS
.DS_Store
.vscode/
.idea/

# Docs-only files (keep image lean; see docs/DOCKER.md on the host)
AGENTS.md
ARCHITECTURE.md
CHANGELOG.md
PRD.md
PLAN-*.md
docs/
README.md
